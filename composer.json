{
	"name": "oliup/oliup-cs-php",
	"description": "Oliup PHP code style rules.",
	"type": "library",
	"keywords": [
		"oliup",
		"php",
		"code style",
		"coding standard",
		"phpcs",
		"php-cs-fixer",
		"phpcompatibility",
		"static analysis"
	],
	"authors": [
		{
			"name": "Emile Silas SARE",
			"role": "lead",
			"homepage": "https://github.com/silassare"
		}
	],
	"config": {
		"platform": {
			"php": "8.1.31"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require": {
		"php": ">=8.1",
		"squizlabs/php_codesniffer": "^4.0",
		"friendsofphp/php-cs-fixer": "^3.94",
		"phpcompatibility/php-compatibility": "^10.0@alpha"
	},
	"require-dev": {
		"roave/security-advisories": "dev-latest"
	},
	"autoload": {
		"psr-4": {
			"OLIUP\\CS\\": "src"
		}
	},
	"bin": [
		"bin/oliup-cs"
	],
	"prefer-stable": true,
	"extra": {
		"branch-alias": {
			"dev-main": "1.x-dev"
		}
	}
}
